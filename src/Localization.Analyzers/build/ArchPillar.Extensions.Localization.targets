<Project>

  <!--
    After a real build, extract the source-language template from the built assembly's IL (Decision D-K) by
    invoking the tool. Gated to build-only (never design-time), so editing in the IDE does not write files
    (Decision D-B). Extraction is per-authoring-assembly, so it runs only where the package is DIRECTLY
    referenced — the project that owns the strings; a project that gets the package transitively has no strings
    of its own and is skipped (it still gets the publish-time merge below). Set
    ArchPillarLocalizationExtractTransitively=true to run it anyway in a project that references the package
    indirectly or wires these targets in by hand (e.g. via Directory.Build) — the escape hatch. Best-effort: a
    missing tool warns rather than failing the build.
  -->
  <Target Name="ArchPillarLocalizationExtractTemplate"
          AfterTargets="Build"
          Condition="'$(ArchPillarLocalizationEmit)' == 'true' and '$(DesignTimeBuild)' != 'true' and '$(BuildingProject)' == 'true'
                     and ('$(ArchPillarLocalizationExtractTransitively)' == 'true' or '@(PackageReference->WithMetadataValue('Identity', 'ArchPillar.Extensions.Localization'))' != '')">
    <!-- Opt out of annotation extraction (display names, descriptions, validation messages) when the consumer
         set ArchPillarLocalizationExtractAnnotations=false, leaving only the in-code call sites in the template. -->
    <PropertyGroup>
      <_ArchPillarExtractAnnotationsArg Condition="'$(ArchPillarLocalizationExtractAnnotations)' == 'false'">--no-annotations</_ArchPillarExtractAnnotationsArg>
    </PropertyGroup>
    <Exec Command="$(ArchPillarLocalizationToolCommand) extract --assembly &quot;$(TargetPath)&quot; --output &quot;$([MSBuild]::NormalizePath('$(ArchPillarLocalizationOutputPath)'))&quot; --source $(ArchPillarLocalizationSourceLanguage) --format $(ArchPillarLocalizationFormat) $(_ArchPillarExtractAnnotationsArg)"
          ContinueOnError="$(ArchPillarLocalizationToolContinueOnError)"
          StandardOutputImportance="low" />
  </Target>

  <!--
    Copies the catalogs beside the application binary, into a Translations folder, so the runtime's ambient
    directory source loads them. The catalogs are already named {AssemblyName}.{culture}.{ext} (the tool writes
    them that way), so two referenced libraries shipping (say) de never collide on one output path; they are
    copied as-is. The source-language catalog ({AssemblyName}.{SourceLanguage}.*) is copied too — it carries any
    edited source wording as overrides above the in-code default (its un-edited echoes are inert at runtime).
    Only the language-neutral Portable Object template (messages.pot) is excluded. Set
    ArchPillarLocalizationCopyTargetsToOutput=false to opt out (e.g. when embedding or merging at publish).
  -->
  <ItemGroup Condition="'$(ArchPillarLocalizationCopyTargetsToOutput)' == 'true' and '$(ArchPillarLocalizationEmbedTargets)' != 'true' and Exists('$(ArchPillarLocalizationOutputPath)')">
    <Content Include="$(ArchPillarLocalizationOutputPath)\**\*.arb;$(ArchPillarLocalizationOutputPath)\**\*.xliff;$(ArchPillarLocalizationOutputPath)\**\*.xlf;$(ArchPillarLocalizationOutputPath)\**\*.po"
             Exclude="$(ArchPillarLocalizationOutputPath)\messages.pot"
             CopyToOutputDirectory="PreserveNewest"
             Link="Translations\%(Filename)%(Extension)" />
  </ItemGroup>

  <!--
    Opt-in (ArchPillarLocalizationEmbedTargets=true): embed the catalogs as standard per-culture SATELLITE
    assemblies instead of copying them as files — for single-file / self-contained publish. Catalogs are named
    {AssemblyName}.{culture}.{ext}, so the culture is the trailing dot-segment of the file name (App.de -> de);
    each lands in <culture>/<AssemblyName>.resources.dll, and the assembly is marked with
    [LocalizationSatelliteCatalogs] so the runtime probes it lazily per culture. The source-language catalog is
    embedded too (as the source-culture satellite) so any edited source wording ships as an override; its
    un-edited echoes are inert at runtime. For trimmed/AOT apps prefer the file (copy) path; embedded resources
    and satellites must be rooted against the trimmer.
  -->
  <ItemGroup Condition="'$(ArchPillarLocalizationEmbedTargets)' == 'true' and Exists('$(ArchPillarLocalizationOutputPath)')">
    <EmbeddedResource Include="$(ArchPillarLocalizationOutputPath)\*.arb;$(ArchPillarLocalizationOutputPath)\*.xliff;$(ArchPillarLocalizationOutputPath)\*.xlf"
                      Culture="$([System.Text.RegularExpressions.Regex]::Replace('%(Filename)', '^.*\.', ''))"
                      Link="%(Filename)%(Extension)" />
    <AssemblyAttribute Include="ArchPillar.Extensions.Localization.LocalizationSatelliteCatalogsAttribute" />
  </ItemGroup>

  <!--
    On publish, flatten the per-library catalogs in the published Translations folder into one bundle per
    culture (the dev many-files layout becomes a production single-bundle-per-culture layout). This is the
    file-system layout used by a server/console app; a Blazor WebAssembly app serves catalogs as static web
    assets and merges them through the static web asset pipeline below instead, so this target is skipped there
    (its $(PublishDir)Translations path does not exist for a WebAssembly publish). Best-effort: if the 'dotnet
    apl' tool is not installed the merge is skipped (ContinueOnError) and the per-library files are kept, so the
    app still works — just with more files. Set ArchPillarLocalizationMergeOnPublish=false to keep the many
    files. The merge reuses the runtime's load, so the bundle resolves identically.
  -->
  <Target Name="ArchPillarLocalizationMergeOnPublish"
          AfterTargets="Publish"
          Condition="'$(ArchPillarLocalizationMergeOnPublish)' == 'true' and Exists('$(PublishDir)Translations')">
    <!--
      Start from a clean intermediate folder. Otherwise a merge that fails this run (ContinueOnError) would
      leave the previous run's bundles in place, and the swap below would publish those stale catalogs.
    -->
    <RemoveDir Directories="$(IntermediateOutputPath)apl-merged" />
    <Exec Command="$(ArchPillarLocalizationToolCommand) merge --input &quot;$([MSBuild]::NormalizePath('$(PublishDir)Translations'))&quot; --output &quot;$([MSBuild]::NormalizePath('$(IntermediateOutputPath)apl-merged'))&quot; --source $(ArchPillarLocalizationSourceLanguage) --format $(ArchPillarLocalizationBundleFormat)"
          ContinueOnError="$(ArchPillarLocalizationToolContinueOnError)"
          StandardOutputImportance="low">
      <Output TaskParameter="ExitCode" PropertyName="_ArchPillarMergeExitCode" />
    </Exec>
    <!-- Only consider the merged bundles when the tool actually succeeded (exit 0); a missing tool or a
         failed merge returns nonzero, leaving the item groups empty so the swap below is a no-op. -->
    <ItemGroup Condition="'$(_ArchPillarMergeExitCode)' == '0'">
      <_ArchPillarMergedCatalogs Include="$(IntermediateOutputPath)apl-merged\*" />
      <_ArchPillarPublishedCatalogs Include="$(PublishDir)Translations\*.arb;$(PublishDir)Translations\*.xliff;$(PublishDir)Translations\*.xlf;$(PublishDir)Translations\*.po" />
    </ItemGroup>
    <!-- Only swap when the merge succeeded and produced bundles; otherwise leave the per-library files in place. -->
    <Delete Files="@(_ArchPillarPublishedCatalogs)" Condition="'@(_ArchPillarMergedCatalogs)' != ''" />
    <Copy SourceFiles="@(_ArchPillarMergedCatalogs)"
          DestinationFiles="@(_ArchPillarMergedCatalogs->'$(PublishDir)Translations\%(Filename)%(Extension)')"
          Condition="'@(_ArchPillarMergedCatalogs)' != ''" />
  </Target>

  <!--
    Serve the catalogs and their manifest (apl-catalogs.json) to a Blazor WebAssembly client as static web
    assets, so the client can fetch them over HTTP and discover what to load — a browser has no file system to
    enumerate. Catalogs are authored under OutputPath (not wwwroot), so they are not auto-discovered; they are
    registered explicitly through the static web asset pipeline, the way the SDK contributes its own computed
    assets (e.g. the JS-initializer module manifest), split by phase so AssetKind alone separates the two
    layouts (no asset removal):
      * Build   (ResolveStaticWebAssetsInputs): the per-library catalogs + a manifest listing them.
      * Publish (ResolvePublishStaticWebAssets): the catalogs merged into one bundle per culture + a manifest
                listing the bundles, so the published app ships the compact layout.
    Both hooks run late enough (PrepareForRun / the publish equivalent) that the tool is built and the
    source-language template has been extracted. These DependsOn properties exist only in Razor/Blazor
    projects, so this is inert elsewhere (a console/server app loads catalogs from the file system; see the
    publish-merge target above). AssetMode is CurrentProject — merging catalogs contributed by referenced
    localized libraries into a WebAssembly client is not yet covered here (the file-system merge above does it
    for a server app).
  -->
  <PropertyGroup Condition="'$(ArchPillarLocalizationEmitManifest)' == 'true'">
    <!-- The Blazor WebAssembly app is the catalog "authority": it gathers every catalog static web asset (its
         own and each referenced library's) and emits the single manifest — and, on publish, merges them into one
         bundle per culture. A referenced Razor library is a "contributor": it registers its catalogs as static
         web assets that flow to the consuming app, and emits no manifest of its own. -->
    <_ArchPillarIsCatalogAuthority Condition="'$(UsingMicrosoftNETSdkBlazorWebAssembly)' == 'true'">true</_ArchPillarIsCatalogAuthority>

    <ResolveStaticWebAssetsInputsDependsOn>
      $(ResolveStaticWebAssetsInputsDependsOn);
      _ArchPillarLocalizationContributeCatalogs;
      _ArchPillarLocalizationAuthorBuildCatalogs
    </ResolveStaticWebAssetsInputsDependsOn>
    <ResolvePublishStaticWebAssetsDependsOn>
      $(ResolvePublishStaticWebAssetsDependsOn);
      _ArchPillarLocalizationAuthorPublishCatalogs
    </ResolvePublishStaticWebAssetsDependsOn>
  </PropertyGroup>

  <!--
    Teach the static web asset pipeline the catalog content types, so the endpoints serve a WebAssembly client's
    catalogs with a correct Content-Type. The SDK's built-in map does not know these extensions, so without this
    they are served as application/octet-stream (a runtime HttpClient fetch still reads them, but the type is
    wrong). ARB is JSON; XLIFF is XML; Portable Object is plain text. Matches the content types the
    ArchPillar.Extensions.Localization.AspNetCore package registers for the classic UseStaticFiles path.
  -->
  <ItemGroup Condition="'$(ArchPillarLocalizationEmitManifest)' == 'true'">
    <StaticWebAssetContentTypeMapping Include="application/json" Pattern="*.arb" Priority="1" Cache="$(StaticWebAssetEndpointDefaultMediaCacheControlHeader)" />
    <StaticWebAssetContentTypeMapping Include="application/xml" Pattern="*.xliff" Priority="1" Cache="$(StaticWebAssetEndpointDefaultMediaCacheControlHeader)" />
    <StaticWebAssetContentTypeMapping Include="application/xml" Pattern="*.xlf" Priority="1" Cache="$(StaticWebAssetEndpointDefaultMediaCacheControlHeader)" />
    <StaticWebAssetContentTypeMapping Include="text/plain" Pattern="*.po" Priority="1" Cache="$(StaticWebAssetEndpointDefaultMediaCacheControlHeader)" />
    <StaticWebAssetContentTypeMapping Include="text/plain" Pattern="*.pot" Priority="1" Cache="$(StaticWebAssetEndpointDefaultMediaCacheControlHeader)" />
  </ItemGroup>

  <!-- Reusable globs for a project's own loose catalogs. The source-language catalog is included (it carries
       edited source wording as overrides; its echoes are inert), so only the neutral PO template is excluded. -->
  <PropertyGroup Condition="'$(ArchPillarLocalizationEmitManifest)' == 'true'">
    <_ArchPillarCatalogRoot>$([MSBuild]::NormalizeDirectory('$(ArchPillarLocalizationOutputPath)'))</_ArchPillarCatalogRoot>
    <_ArchPillarCatalogInclude>$(_ArchPillarCatalogRoot)*.arb;$(_ArchPillarCatalogRoot)*.xliff;$(_ArchPillarCatalogRoot)*.xlf;$(_ArchPillarCatalogRoot)*.po</_ArchPillarCatalogInclude>
    <_ArchPillarCatalogExclude>$(_ArchPillarCatalogRoot)messages.pot</_ArchPillarCatalogExclude>
  </PropertyGroup>

  <!--
    Contributor (a referenced Razor library): register this library's own catalogs as static web assets with
    AssetMode=All so they flow to the consuming app, tagged so the app can find them. No manifest — the app
    authors it. Skipped on the authority (the WebAssembly app gathers its own catalogs directly below).
  -->
  <Target Name="_ArchPillarLocalizationContributeCatalogs"
          Condition="'$(ArchPillarLocalizationEmitManifest)' == 'true' and '$(_ArchPillarIsCatalogAuthority)' != 'true' and '$(OutputType)' == 'Library' and Exists('$(ArchPillarLocalizationOutputPath)')">
    <ItemGroup>
      <_ArchPillarOwnCatalogRaw Include="$(_ArchPillarCatalogInclude)" Exclude="$(_ArchPillarCatalogExclude)" />
      <_ArchPillarOwnCatalog Include="@(_ArchPillarOwnCatalogRaw)">
        <RelativePath>Translations/%(Filename)%(Extension)</RelativePath>
      </_ArchPillarOwnCatalog>
    </ItemGroup>

    <DefineStaticWebAssets Condition="'@(_ArchPillarOwnCatalog)' != ''"
      CandidateAssets="@(_ArchPillarOwnCatalog)"
      SourceId="$(PackageId)" SourceType="Computed"
      BasePath="$(StaticWebAssetBasePath)" ContentRoot="$(_ArchPillarCatalogRoot)"
      AssetKind="All" AssetMode="All" AssetRole="Primary"
      AssetTraitName="ArchPillarLocalizationCatalog" AssetTraitValue="Catalog"
      FingerprintCandidates="$(StaticWebAssetsFingerprintContent)" FingerprintPatterns="@(StaticWebAssetFingerprintPattern)">
      <Output TaskParameter="Assets" ItemName="StaticWebAsset" />
      <Output TaskParameter="Assets" ItemName="_ArchPillarContributedCatalog" />
    </DefineStaticWebAssets>

    <DefineStaticWebAssetEndpoints Condition="'@(_ArchPillarContributedCatalog)' != ''"
      CandidateAssets="@(_ArchPillarContributedCatalog)"
      ExistingEndpoints="@(StaticWebAssetEndpoint)" ContentTypeMappings="@(StaticWebAssetContentTypeMapping)">
      <Output TaskParameter="Endpoints" ItemName="StaticWebAssetEndpoint" />
    </DefineStaticWebAssetEndpoints>
  </Target>

  <!--
    Authority (build): gather the app's own catalogs (loose files in OutputPath) and every referenced library's
    catalog assets (by trait), collect them into one folder, and re-home them under Translations/ as Build
    assets, then emit one manifest listing them. The referenced assets are removed at their original
    _content/<lib>/ location so each catalog is served once.
  -->
  <Target Name="_ArchPillarLocalizationAuthorBuildCatalogs"
          Condition="'$(ArchPillarLocalizationEmitManifest)' == 'true' and '$(_ArchPillarIsCatalogAuthority)' == 'true'">
    <PropertyGroup>
      <_ArchPillarBuildCollectDir>$([MSBuild]::NormalizeDirectory('$(IntermediateOutputPath)apl-build'))</_ArchPillarBuildCollectDir>
      <_ArchPillarBuildManifestDir>$([MSBuild]::NormalizeDirectory('$(IntermediateOutputPath)apl-build-manifest'))</_ArchPillarBuildManifestDir>
    </PropertyGroup>

    <ItemGroup>
      <_ArchPillarOwnCatalogFile Condition="Exists('$(ArchPillarLocalizationOutputPath)')" Include="$(_ArchPillarCatalogInclude)" Exclude="$(_ArchPillarCatalogExclude)" />
      <_ArchPillarReferencedCatalog Include="@(StaticWebAsset)" Condition="'%(StaticWebAsset.AssetTraitName)' == 'ArchPillarLocalizationCatalog'" />
    </ItemGroup>

    <RemoveDir Directories="$(_ArchPillarBuildCollectDir)" />
    <MakeDir Directories="$(_ArchPillarBuildCollectDir)" />
    <Copy Condition="'@(_ArchPillarOwnCatalogFile)@(_ArchPillarReferencedCatalog)' != ''"
          SourceFiles="@(_ArchPillarOwnCatalogFile);@(_ArchPillarReferencedCatalog)"
          DestinationFolder="$(_ArchPillarBuildCollectDir)" />

    <ItemGroup>
      <!-- The referenced catalogs are re-homed under Translations/; drop them at their _content/<lib>/ origin. -->
      <StaticWebAsset Remove="@(_ArchPillarReferencedCatalog)" />

      <_ArchPillarBuildCollected Include="$(_ArchPillarBuildCollectDir)*.arb;$(_ArchPillarBuildCollectDir)*.xliff;$(_ArchPillarBuildCollectDir)*.xlf;$(_ArchPillarBuildCollectDir)*.po" />
      <_ArchPillarBuildCatalog Include="@(_ArchPillarBuildCollected)">
        <RelativePath>Translations/%(Filename)%(Extension)</RelativePath>
      </_ArchPillarBuildCatalog>
    </ItemGroup>

    <DefineStaticWebAssets Condition="'@(_ArchPillarBuildCatalog)' != ''"
      CandidateAssets="@(_ArchPillarBuildCatalog)"
      SourceId="$(PackageId)" SourceType="Computed"
      BasePath="$(StaticWebAssetBasePath)" ContentRoot="$(_ArchPillarBuildCollectDir)"
      AssetKind="Build" AssetMode="CurrentProject" AssetRole="Primary"
      FingerprintCandidates="$(StaticWebAssetsFingerprintContent)" FingerprintPatterns="@(StaticWebAssetFingerprintPattern)">
      <Output TaskParameter="Assets" ItemName="StaticWebAsset" />
      <Output TaskParameter="Assets" ItemName="_ArchPillarBuildCatalogAsset" />
    </DefineStaticWebAssets>

    <MakeDir Condition="'@(_ArchPillarBuildCatalog)' != ''" Directories="$(_ArchPillarBuildManifestDir)" />
    <Exec Condition="'@(_ArchPillarBuildCatalog)' != ''"
          Command="$(ArchPillarLocalizationToolCommand) manifest --input &quot;$(_ArchPillarBuildCollectDir)&quot; --output &quot;$(_ArchPillarBuildManifestDir)apl-catalogs.json&quot; --source $(ArchPillarLocalizationSourceLanguage)"
          ContinueOnError="$(ArchPillarLocalizationToolContinueOnError)" StandardOutputImportance="low" />

    <ItemGroup>
      <_ArchPillarBuildManifestFile Include="$(_ArchPillarBuildManifestDir)apl-catalogs.json" Condition="Exists('$(_ArchPillarBuildManifestDir)apl-catalogs.json')">
        <RelativePath>Translations/apl-catalogs.json</RelativePath>
      </_ArchPillarBuildManifestFile>
    </ItemGroup>
    <DefineStaticWebAssets Condition="'@(_ArchPillarBuildManifestFile)' != ''"
      CandidateAssets="@(_ArchPillarBuildManifestFile)" SourceId="$(PackageId)" SourceType="Computed"
      BasePath="$(StaticWebAssetBasePath)" ContentRoot="$(_ArchPillarBuildManifestDir)"
      AssetKind="Build" AssetMode="CurrentProject" AssetRole="Primary"
      FingerprintCandidates="$(StaticWebAssetsFingerprintContent)" FingerprintPatterns="@(StaticWebAssetFingerprintPattern)">
      <Output TaskParameter="Assets" ItemName="StaticWebAsset" />
      <Output TaskParameter="Assets" ItemName="_ArchPillarBuildManifestAsset" />
    </DefineStaticWebAssets>

    <DefineStaticWebAssetEndpoints Condition="'@(_ArchPillarBuildCatalogAsset)@(_ArchPillarBuildManifestAsset)' != ''"
      CandidateAssets="@(_ArchPillarBuildCatalogAsset);@(_ArchPillarBuildManifestAsset)"
      ExistingEndpoints="@(StaticWebAssetEndpoint)" ContentTypeMappings="@(StaticWebAssetContentTypeMapping)">
      <Output TaskParameter="Endpoints" ItemName="StaticWebAssetEndpoint" />
    </DefineStaticWebAssetEndpoints>
  </Target>

  <!--
    Authority (publish): same gather as the build, but flatten the app's own and every referenced library's
    catalogs into one bundle per culture, register the bundles, and remove the per-library catalogs from the
    publish set so only the bundles ship.
  -->
  <Target Name="_ArchPillarLocalizationAuthorPublishCatalogs"
          Condition="'$(ArchPillarLocalizationEmitManifest)' == 'true' and '$(_ArchPillarIsCatalogAuthority)' == 'true'">
    <PropertyGroup>
      <_ArchPillarPubCollectDir>$([MSBuild]::NormalizeDirectory('$(IntermediateOutputPath)apl-pub'))</_ArchPillarPubCollectDir>
      <_ArchPillarBundleDir>$([MSBuild]::NormalizeDirectory('$(IntermediateOutputPath)apl-pub-bundles'))</_ArchPillarBundleDir>
      <_ArchPillarPubManifestDir>$([MSBuild]::NormalizeDirectory('$(IntermediateOutputPath)apl-pub-manifest'))</_ArchPillarPubManifestDir>
    </PropertyGroup>

    <ItemGroup>
      <_ArchPillarOwnCatalogFile Condition="Exists('$(ArchPillarLocalizationOutputPath)')" Include="$(_ArchPillarCatalogInclude)" Exclude="$(_ArchPillarCatalogExclude)" />
      <_ArchPillarReferencedCatalog Include="@(StaticWebAsset)" Condition="'%(StaticWebAsset.AssetTraitName)' == 'ArchPillarLocalizationCatalog'" />
    </ItemGroup>

    <RemoveDir Directories="$(_ArchPillarPubCollectDir);$(_ArchPillarBundleDir)" />
    <MakeDir Directories="$(_ArchPillarPubCollectDir);$(_ArchPillarBundleDir);$(_ArchPillarPubManifestDir)" />
    <Copy Condition="'@(_ArchPillarOwnCatalogFile)@(_ArchPillarReferencedCatalog)' != ''"
          SourceFiles="@(_ArchPillarOwnCatalogFile);@(_ArchPillarReferencedCatalog)"
          DestinationFolder="$(_ArchPillarPubCollectDir)" />

    <Exec Condition="'@(_ArchPillarOwnCatalogFile)@(_ArchPillarReferencedCatalog)' != ''"
          Command="$(ArchPillarLocalizationToolCommand) merge --input &quot;$(_ArchPillarPubCollectDir)&quot; --output &quot;$(_ArchPillarBundleDir)&quot; --source $(ArchPillarLocalizationSourceLanguage) --format $(ArchPillarLocalizationBundleFormat)"
          ContinueOnError="$(ArchPillarLocalizationToolContinueOnError)" StandardOutputImportance="low" />

    <ItemGroup>
      <!-- The bundles replace the per-library catalogs; drop the referenced ones from the publish set. -->
      <StaticWebAsset Remove="@(_ArchPillarReferencedCatalog)" />

      <_ArchPillarBundleRaw Include="$(_ArchPillarBundleDir)*.arb;$(_ArchPillarBundleDir)*.xliff;$(_ArchPillarBundleDir)*.xlf;$(_ArchPillarBundleDir)*.po" />
      <_ArchPillarBundle Include="@(_ArchPillarBundleRaw)">
        <RelativePath>Translations/%(Filename)%(Extension)</RelativePath>
      </_ArchPillarBundle>
    </ItemGroup>

    <DefineStaticWebAssets Condition="'@(_ArchPillarBundle)' != ''"
      CandidateAssets="@(_ArchPillarBundle)"
      SourceId="$(PackageId)" SourceType="Computed"
      BasePath="$(StaticWebAssetBasePath)" ContentRoot="$(_ArchPillarBundleDir)"
      AssetKind="Publish" AssetMode="CurrentProject" AssetRole="Primary"
      FingerprintCandidates="$(StaticWebAssetsFingerprintContent)" FingerprintPatterns="@(StaticWebAssetFingerprintPattern)">
      <Output TaskParameter="Assets" ItemName="StaticWebAsset" />
      <Output TaskParameter="Assets" ItemName="_ArchPillarPubBundleAsset" />
    </DefineStaticWebAssets>

    <Exec Condition="'@(_ArchPillarBundle)' != ''"
          Command="$(ArchPillarLocalizationToolCommand) manifest --input &quot;$(_ArchPillarBundleDir)&quot; --output &quot;$(_ArchPillarPubManifestDir)apl-catalogs.json&quot; --source $(ArchPillarLocalizationSourceLanguage)"
          ContinueOnError="$(ArchPillarLocalizationToolContinueOnError)" StandardOutputImportance="low" />

    <ItemGroup>
      <_ArchPillarPubManifestFile Include="$(_ArchPillarPubManifestDir)apl-catalogs.json" Condition="Exists('$(_ArchPillarPubManifestDir)apl-catalogs.json')">
        <RelativePath>Translations/apl-catalogs.json</RelativePath>
      </_ArchPillarPubManifestFile>
    </ItemGroup>
    <DefineStaticWebAssets Condition="'@(_ArchPillarPubManifestFile)' != ''"
      CandidateAssets="@(_ArchPillarPubManifestFile)" SourceId="$(PackageId)" SourceType="Computed"
      BasePath="$(StaticWebAssetBasePath)" ContentRoot="$(_ArchPillarPubManifestDir)"
      AssetKind="Publish" AssetMode="CurrentProject" AssetRole="Primary"
      FingerprintCandidates="$(StaticWebAssetsFingerprintContent)" FingerprintPatterns="@(StaticWebAssetFingerprintPattern)">
      <Output TaskParameter="Assets" ItemName="StaticWebAsset" />
      <Output TaskParameter="Assets" ItemName="_ArchPillarPubManifestAsset" />
    </DefineStaticWebAssets>

    <DefineStaticWebAssetEndpoints Condition="'@(_ArchPillarPubBundleAsset)@(_ArchPillarPubManifestAsset)' != ''"
      CandidateAssets="@(_ArchPillarPubBundleAsset);@(_ArchPillarPubManifestAsset)"
      ExistingEndpoints="@(StaticWebAssetEndpoint)" ContentTypeMappings="@(StaticWebAssetContentTypeMapping)">
      <Output TaskParameter="Endpoints" ItemName="StaticWebAssetEndpoint" />
    </DefineStaticWebAssetEndpoints>
  </Target>

</Project>
