<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Extract this library's template like any project, but it ships its catalog as an embedded satellite
         (below), so don't ALSO copy loose catalog files to the output — disable only the copy step, not the
         whole authoring wiring (which would stop extraction entirely). -->
    <ArchPillarLocalizationCopyTargetsToOutput>false</ArchPillarLocalizationCopyTargetsToOutput>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <RootNamespace>Acme.Greeting</RootNamespace>
    <AssemblyName>Acme.Greeting</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Localization\ArchPillar.Extensions.Localization.csproj" />
  </ItemGroup>

  <!--
    Batteries included: ship the German catalog inside this library's own DLL as a culture satellite
    (Culture="de" routes de.xliff to de/Acme.Greeting.resources.dll), and mark the assembly so the ambient
    store discovers it. A consuming app needs no configuration, no DI, and no files on disk.
  -->
  <ItemGroup>
    <None Remove="Translations/Acme.Greeting.de.xliff" />
    <EmbeddedResource Include="Translations/Acme.Greeting.de.xliff" Culture="de" Link="Acme.Greeting.de.xliff" />
    <AssemblyAttribute Include="ArchPillar.Extensions.Localization.LocalizationSatelliteCatalogsAttribute" />
  </ItemGroup>

</Project>
