<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <!-- This sample fetches its catalog from wwwroot over HTTP, not the loose-file extract path, so opt out of
         the samples' automatic package-build wiring. -->
    <ArchPillarLocalizationSampleAuthoring>false</ArchPillarLocalizationSampleAuthoring>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>$(NoWarn);IDE0005</NoWarn>
    <RootNamespace>Localization.WasmSample</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Localization\ArchPillar.Extensions.Localization.csproj" />
    <ProjectReference Include="..\..\..\src\Localization.StringLocalizer\ArchPillar.Extensions.Localization.StringLocalizer.csproj" />
  </ItemGroup>

</Project>
