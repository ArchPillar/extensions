  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Localization\ArchPillar.Extensions.Localization.csproj" />
    <ProjectReference Include="..\..\..\src\Localization.DependencyInjection\ArchPillar.Extensions.Localization.DependencyInjection.csproj" />
  </ItemGroup>

</Project>
