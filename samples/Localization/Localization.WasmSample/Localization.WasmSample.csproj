<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <!-- Extract this app's template like any project, but it serves catalogs from wwwroot over HTTP rather
         than the loose-file copy path, so disable only the copy step, not the whole authoring wiring. -->
    <ArchPillarLocalizationCopyTargetsToOutput>false</ArchPillarLocalizationCopyTargetsToOutput>
    <!-- Author catalogs straight into wwwroot, so they are served as static web assets and fetched over HTTP at
         runtime. The build also generates the apl-catalogs.json manifest and registers it as a static web asset
         through the Razor pipeline (see the package targets), so the client can discover the catalogs. -->
    <ArchPillarLocalizationOutputPath>$(MSBuildProjectDirectory)/wwwroot/Translations</ArchPillarLocalizationOutputPath>
    <!-- This sample is trimmed by default (Blazor WASM) but must still author + serve its catalogs through the
         build pipeline, so it opts into the samples' authoring wiring explicitly. -->
    <ArchPillarLocalizationSampleAuthoring>true</ArchPillarLocalizationSampleAuthoring>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>$(NoWarn);IDE0005</NoWarn>
    <RootNamespace>Localization.WasmSample</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Localization\ArchPillar.Extensions.Localization.csproj" />
    <ProjectReference Include="..\..\..\src\Localization.StringLocalizer\ArchPillar.Extensions.Localization.StringLocalizer.csproj" />
  </ItemGroup>

</Project>
