@page "/"
@using Ambient = ArchPillar.Extensions.Localization.Localizer
@inject ILocalizer Localizer
@inject IStringLocalizer<Home> Strings

<h1>@Localizer.Translate("home.title", "Inbox")</h1>

<ul>
    @for (var count = 0; count <= 2; count++)
    {
        <li>
            @Localizer.Translate(
                "inbox.count",
                "{count, plural, =0 {No messages} one {# message} other {# messages}}",
                ("count", count))
        </li>
    }
</ul>

@{
    // The IStringLocalizer<T> adapter: the name is the key, positional arguments map to {0}, and a
    // missing entry returns the name (English has no override here).
    LocalizedString summary = Strings["inbox.summary", 3];
}
<p>@summary.Value @(summary.ResourceNotFound ? "(no override — showing the key)" : string.Empty)</p>

@* A string from a referenced library (Localization.WasmLibrary). Its German comes from that library's own
   catalog, which the build gathered into this app's manifest and (on publish) merged into one bundle. *@
<p>@Acme.WasmGreeting.Greeter.Greeting</p>

<nav>
    <button @onclick="@(() => SetCulture("en"))">English</button>
    <button @onclick="@(() => SetCulture("de"))">Deutsch</button>
    <span> — current: @CultureInfo.CurrentUICulture.Name</span>
</nav>

@code {
    // Only the active language was loaded at startup, so load the picked one on demand first — the manifest
    // provider was registered by UseArchPillarLocalizationAsync, so the component needs no HttpClient and the
    // fetch is instant from the PWA cache. Then set the culture (the app's concern, not the library's). This is a
    // click handler, so Blazor re-renders the page when it returns — and the awaited preload means the catalogs
    // are already in place for that render, no reactive refresh needed.
    private async Task SetCulture(string name)
    {
        CultureInfo culture = CultureInfo.GetCultureInfo(name);
        await Ambient.LoadCultureAsync(culture);
        CultureInfo.CurrentUICulture = culture;
        CultureInfo.CurrentCulture = culture;
    }
}
