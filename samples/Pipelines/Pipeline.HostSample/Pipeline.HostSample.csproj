<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <!-- Override library defaults — this is an application, not a library -->
        <GenerateDocumentationFile>false</GenerateDocumentationFile>
        <Nullable>enable</Nullable>
        <NoWarn>$(NoWarn);IDE0005</NoWarn>
        <RootNamespace>Pipeline.HostSample</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="../../../src/Pipelines/ArchPillar.Extensions.Pipelines.csproj" />
        <ProjectReference Include="../../../src/Pipelines.DependencyInjection/ArchPillar.Extensions.Pipelines.DependencyInjection.csproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Hosting" />
        <PackageReference Include="Microsoft.Extensions.Logging.Console" />
    </ItemGroup>

</Project>
